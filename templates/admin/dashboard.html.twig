{% extends 'base.html.twig' %}

{% block title %}Dashboard Admin — Vite & Gourmand{% endblock %}

{% block content %}
<section class="py-5">
    <div class="container">
        <h1 class="fw-bold mb-4" style="color: #1A6BAD;">
            📊 Dashboard Admin
        </h1>

        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <div class="card text-white shadow-sm"
                     style="background-color: #1A6BAD;">
                    <div class="card-body text-center">
                        <h2 class="display-4 fw-bold">{{ nb_menus }}</h2>
                        <p class="mb-0">🍽️ Menus disponibles</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-white shadow-sm"
                     style="background-color: #E8701A;">
                    <div class="card-body text-center">
                        <h2 class="display-4 fw-bold">{{ nb_commandes }}</h2>
                        <p class="mb-0">📦 Commandes en cours</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-white shadow-sm"
                     style="background-color: #2E8B57;">
                    <div class="card-body text-center">
                        <h2 class="display-4 fw-bold">0</h2>
                        <p class="mb-0">⭐ Avis à valider</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-md-3">
                <a href="{{ path('app_admin_menus') }}"
                   class="btn btn-primary w-100 btn-lg">
                    🍽️ Gérer les menus
                </a>
            </div>
            <div class="col-md-3">
                <a href="{{ path('app_admin_commandes') }}"
                   class="btn btn-warning w-100 btn-lg">
                    📦 Gérer les commandes
                </a>
            </div>
            <div class="col-md-3">
                <a href="{{ path('app_admin_avis') }}"
                   class="btn btn-success w-100 btn-lg">
                    ⭐ Gérer les avis
                </a>
            </div>
            {% if is_granted('ROLE_ADMIN') %}
            <div class="col-md-3">
                <a href="{{ path('app_admin_employes') }}"
                   class="btn btn-danger w-100 btn-lg">
                    👥 Gérer les employés
                </a>
            </div>
            {% endif %}
        </div>
    </div>
</section>
{% endblock %}
