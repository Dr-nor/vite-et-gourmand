{% extends 'base.html.twig' %}

{% block title %}Mon Profil — Vite & Gourmand{% endblock %}

{% block content %}
<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <h1 class="fw-bold mb-4" style="color: #1A6BAD;">
                    👤 Mon Profil
                </h1>
                <div class="card shadow-sm">
                    <div class="card-body">
                        <p><strong>Email :</strong> {{ user.email }}</p>
                        <p><strong>Rôle :</strong>
                            {% if is_granted('ROLE_ADMIN') %}
                                Administrateur
                            {% elseif is_granted('ROLE_EMPLOYE') %}
                                Employé
                            {% else %}
                                Client
                            {% endif %}
                        </p>
                        <a href="{{ path('app_user_commandes') }}"
                           class="btn btn-primary mt-3">
                            Voir mes commandes
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
