{% extends 'base.html.twig' %}

{% block title %}Mes Commandes — Vite & Gourmand{% endblock %}

{% block content %}
<section class="py-5">
    <div class="container">
        <h1 class="fw-bold mb-4" style="color: #1A6BAD;">📦 Mes Commandes</h1>

        {% if commandes is empty %}
        <div class="alert alert-info">
            Vous n'avez pas encore de commandes.
            <a href="{{ path('app_menu_index') }}" class="alert-link">
                Voir nos menus
            </a>
        </div>
        {% else %}
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-primary">
                    <tr>
                        <th>N° Commande</th>
                        <th>Menu</th>
                        <th>Prix</th>
                        <th>Statut</th>
                    </tr>
                </thead>
                <tbody>
                    {% for commande in commandes %}
                    <tr>
                        <td>#{{ commande.id }}</td>
                        <td>{{ commande.menu.titre }}</td>
                        <td>{{ commande.prixTotal }} €</td>
                        <td>
                            <span class="badge bg-warning">
                                {{ commande.statut }}
                            </span>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% endif %}
    </div>
</section>
{% endblock %}
