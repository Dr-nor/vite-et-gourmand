{% extends 'base.html.twig' %}

{% block title %}Accueil — Vite & Gourmand{% endblock %}

{% block content %}
<section class="py-5 text-white text-center" style="background-color: #1A6BAD;">
    <div class="container">
        <h1 class="display-4 fw-bold">🍽️ Vite & Gourmand</h1>
        <p class="lead">Traiteur & livraison de repas à Bordeaux — Fait maison, livré chez vous</p>
        <a href="{{ path('app_menu_index') }}" class="btn btn-warning btn-lg mt-3 fw-bold">
            Voir nos menus
        </a>
    </div>
</section>

<section class="py-5 bg-light">
    <div class="container">
        <h2 class="text-center fw-bold mb-4" style="color: #1A6BAD;">Nos menus vedettes</h2>
        <div class="row g-4">
            {% for menu in menus %}
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">{{ menu.titre }}</h5>
                        <p class="card-text text-muted">{{ menu.description }}</p>
                        <span class="badge bg-primary fs-6">{{ menu.prix }} €</span>
                    </div>
                    <div class="card-footer">
                        <a href="{{ path('app_menu_show', {id: menu.id}) }}"
                           class="btn btn-outline-primary w-100">Voir le menu</a>
                    </div>
                </div>
            </div>
            {% else %}
            <div class="col-12 text-center text-muted">
                <p>Aucun menu disponible pour le moment.</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endblock %}
