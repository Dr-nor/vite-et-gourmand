{% extends 'base.html.twig' %}

{% block title %}{{ menu.titre }} — Vite & Gourmand{% endblock %}

{% block content %}
<section class="py-5">
    <div class="container">
        <a href="{{ path('app_menu_index') }}" class="btn btn-outline-secondary mb-4">
            ← Retour aux menus
        </a>
        <div class="row">
            <div class="col-md-8">
                <h1 class="fw-bold" style="color: #1A6BAD;">{{ menu.titre }}</h1>
                <p class="lead text-muted">{{ menu.description }}</p>
                <span class="badge bg-primary fs-5 mb-4">{{ menu.prix }} €</span>
            </div>
            <div class="col-md-4 text-center">
                {% if app.user %}
                <a href="{{ path('app_commande_new', {menuId: menu.id}) }}"
                   class="btn btn-warning btn-lg fw-bold w-100">
                    🛒 Commander ce menu
                </a>
                {% else %}
                <a href="{{ path('app_login') }}"
                   class="btn btn-outline-primary btn-lg w-100">
                    Connectez-vous pour commander
                </a>
                {% endif %}
            </div>
        </div>
    </div>
</section>
{% endblock %}
